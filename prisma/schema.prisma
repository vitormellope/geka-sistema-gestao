generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum Role {
  vendedor
  assistente
  orcamentista
  gerente
  projetista
}

// ─── Models ─────────────────────────────────────────────────────────────────

model User {
  id           Int      @id @default(autoincrement())
  name         String   @db.VarChar(150)
  email        String   @unique @db.VarChar(255)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  role         Role
  active       Boolean  @default(true)

  demandsAsSeller    Demand[]       @relation("seller")
  demandsAsAssistant Demand[]       @relation("assistant")
  historyLogs        HistoryLog[]
  notifications      Notification[]
  attachments        Attachment[]
  campaignsAsSeller  Campaign[]

  @@map("users")
}

model Category {
  id           Int    @id @default(autoincrement())
  name         String @unique @db.VarChar(150)
  fieldsSchema Json   @default("[]") @map("fields_schema")

  demands Demand[]

  @@map("categories")
}

model Campaign {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(255)
  description String?  @db.Text
  client      String   @db.VarChar(255)
  sellerId    Int      @map("seller_id")
  status      String   @default("em_desenvolvimento") @db.VarChar(50)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  seller  User     @relation(fields: [sellerId], references: [id])
  demands Demand[]

  @@map("campaigns")
}

model Demand {
  id             Int       @id @default(autoincrement())
  title          String    @db.VarChar(255)
  sellerId       Int       @map("seller_id")
  assistantId    Int?      @map("assistant_id")
  client         String    @db.VarChar(255)
  categoryId     Int       @map("category_id")
  campaignId     Int?      @map("campaign_id")
  deadline       DateTime?
  slaDate        DateTime? @map("sla_date")
  status         String    @default("nova") @db.VarChar(50)
  priority       String    @default("normal") @db.VarChar(20)
  estimatedValue Float?    @map("estimated_value")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  seller       User              @relation("seller", fields: [sellerId], references: [id])
  assistant    User?             @relation("assistant", fields: [assistantId], references: [id])
  category     Category          @relation(fields: [categoryId], references: [id])
  campaign     Campaign?         @relation(fields: [campaignId], references: [id])
  fieldValues  DemandFieldValue[]
  historyLogs  HistoryLog[]
  attachments  Attachment[]
  notifications Notification[]

  @@map("demands")
}

model DemandFieldValue {
  id         Int     @id @default(autoincrement())
  demandId   Int     @map("demand_id")
  fieldName  String  @map("field_name") @db.VarChar(100)
  fieldValue String? @map("field_value") @db.Text

  demand Demand @relation(fields: [demandId], references: [id], onDelete: Cascade)

  @@map("demand_field_values")
}

model HistoryLog {
  id          Int      @id @default(autoincrement())
  demandId    Int      @map("demand_id")
  timestamp   DateTime @default(now())
  userId      Int      @map("user_id")
  prevStatus  String?  @map("prev_status") @db.VarChar(50)
  newStatus   String   @map("new_status") @db.VarChar(50)
  observation String?  @db.Text

  demand Demand @relation(fields: [demandId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  @@map("history_logs")
}

model Attachment {
  id         Int      @id @default(autoincrement())
  demandId   Int      @map("demand_id")
  filename   String   @db.VarChar(255)
  filePath   String   @map("file_path") @db.VarChar(500)
  fileType   String   @map("file_type") @db.VarChar(100)
  fileSize   Int      @map("file_size")
  uploadedAt DateTime @default(now()) @map("uploaded_at")
  uploadedBy Int      @map("uploaded_by")

  demand   Demand @relation(fields: [demandId], references: [id], onDelete: Cascade)
  uploader User   @relation(fields: [uploadedBy], references: [id])

  @@map("attachments")
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  demandId  Int?     @map("demand_id")
  message   String   @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user   User    @relation(fields: [userId], references: [id])
  demand Demand? @relation(fields: [demandId], references: [id], onDelete: SetNull)

  @@map("notifications")
}
